# Postgres connection string
DATABASE_URL=postgresql://postgres:pg@localhost:5432/orqly

# Better Auth — generate a secret with `npx @better-auth/cli secret`
BETTER_AUTH_SECRET=change-me
BETTER_AUTH_URL=http://localhost:3000

# Optional: Google sign-in (buttons hidden until both are set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: reject requests to loopback/private IPs from /api/execute (recommended in production)
# EXECUTE_BLOCK_PRIVATE_IPS=1
