# Postgres connection string (see README → Environment variables)
# Local Docker: docker run -d -e POSTGRES_PASSWORD=pg -e POSTGRES_DB=orqly -p 5432:5432 postgres:16
# Hosted: copy the postgresql://… URL from Neon / Supabase / Railway (append ?sslmode=require if needed)
DATABASE_URL=postgresql://postgres:pg@localhost:5432/orqly

# Session signing secret — generate with: npx @better-auth/cli@latest secret  (or: openssl rand -hex 32)
BETTER_AUTH_SECRET=change-me

# The URL the app is served from (no trailing slash); your deployed origin in production
BETTER_AUTH_URL=http://localhost:3000

# Optional: Google sign-in ("Continue with Google" stays hidden until both are set).
# Create an OAuth Web client at console.cloud.google.com → APIs & Services → Credentials,
# with redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional, recommended in production: reject /api/execute requests to loopback/private IPs.
# Leave unset in local dev — the seeded demo targets the app's own /api/echo.
# EXECUTE_BLOCK_PRIVATE_IPS=1
